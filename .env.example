# Database Configuration
# For production, use a PostgreSQL connection string from Neon, Supabase, or Vercel Postgres
# Example: postgres://user:password@host:5432/database?sslmode=require

# For local development with Prisma dev server:
# DATABASE_URL="prisma+postgres://localhost:51213/?api_key=..."
# DATABASE_URL_TCP="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"

# For production (Neon, Supabase, etc):
DATABASE_URL="postgres://user:password@host:5432/database?sslmode=require"

# Admin Panel
ADMIN_PASSWORD="your-admin-password"
